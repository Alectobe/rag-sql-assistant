<?xml version="1.0"?>
<!--
  Read-only profile + user for the assistant.
  The LLM-generated SQL only ever runs under this user, so even a successful
  prompt-injection cannot mutate data or exhaust the cluster.
-->
<clickhouse>
    <profiles>
        <assistant_readonly>
            <!-- 1 = only SELECT and read-only settings; no INSERT/ALTER/DDL. -->
            <readonly>1</readonly>
            <allow_ddl>0</allow_ddl>
            <max_result_rows>200</max_result_rows>
            <max_result_bytes>10000000</max_result_bytes>
            <result_overflow_mode>break</result_overflow_mode>
            <max_execution_time>15</max_execution_time>
            <max_rows_to_read>50000000</max_rows_to_read>
            <max_bytes_to_read>1000000000</max_bytes_to_read>
            <read_overflow_mode>throw</read_overflow_mode>
        </assistant_readonly>
    </profiles>

    <users>
        <assistant_ro>
            <!-- Dev-only password. Override for anything beyond local Docker. -->
            <password>readonly_pw</password>
            <profile>assistant_readonly</profile>
            <quota>default</quota>
            <networks>
                <ip>::/0</ip>
            </networks>
            <access_management>0</access_management>
        </assistant_ro>
    </users>
</clickhouse>
