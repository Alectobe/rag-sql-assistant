# --- LLM backend ---
# "anthropic" = Claude API (best quality, fastest to validate the hypothesis).
# "local"     = any OpenAI-compatible endpoint (Ollama / vLLM serving Qwen, etc.),
#               so SQL + your data never leave the network. Switch with one var.
LLM_BACKEND=anthropic

# --- Anthropic backend ---
ANTHROPIC_API_KEY=sk-ant-...
# Models for the anthropic backend.
#   Generation (Text-to-SQL):  claude-opus-4-8 (default) | claude-sonnet-4-6
#   Interpretation (NL answer): claude-haiku-4-5 (default) | claude-sonnet-4-6
GENERATION_MODEL=claude-opus-4-8
INTERPRETATION_MODEL=claude-haiku-4-5

# --- Local backend (OpenAI-compatible) ---
# Ollama default endpoint shown. On M2 Pro 16GB, qwen2.5-coder:7b runs comfortably.
# When LLM_BACKEND=local, set GENERATION_MODEL / INTERPRETATION_MODEL to local names:
#   GENERATION_MODEL=qwen2.5-coder:7b
#   INTERPRETATION_MODEL=qwen2.5-coder:7b
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama

# --- ClickHouse (local dev via docker-compose) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=assistant_ro
CLICKHOUSE_PASSWORD=readonly_pw
CLICKHOUSE_DATABASE=analytics

# --- Pipeline behaviour ---
MAX_SQL_RETRIES=1
MAX_RESULT_ROWS=200
QUERY_TIMEOUT_SECONDS=15
